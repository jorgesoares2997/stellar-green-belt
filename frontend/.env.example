# StellarVault Environment Variables
# Copy this file to .env.local and fill in the values after deployment

# The ID of your deployed Vault contract
NEXT_PUBLIC_VAULT_CONTRACT_ID=XXXXXXXXXXXX

# The ID of the underlying Token contract (e.g. USDC on Testnet)
NEXT_PUBLIC_TOKEN_CONTRACT_ID=XXXXXXXXXXXXX

# Stellar Network Configuration
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
